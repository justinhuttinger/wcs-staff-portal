{
  "name": "wcs-dayone-kiosk",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "author": "WCS",
  "description": "Day One Tracker Kiosk for Keizer",
  "build": {
    "appId": "com.wcs.d1-tracker",
    "productName": "D1 Tracker",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "installerIcon": "icon.ico"
    }
  }
}
